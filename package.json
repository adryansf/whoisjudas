{
	"name": "whoisjudas",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"dev:next": "turbo dev",
		"build": "turbo build",
		"start": "NODE_ENV=production node server.js",
		"check-types": "turbo check-types",
		"dev:web": "turbo dev",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@whoisjudas/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@types/node": "^22.13.14",
		"@whoisjudas/config": "workspace:*",
		"turbo": "^2.9.6",
		"typescript": "^5"
	},
	"packageManager": "pnpm@10.17.1"
}
